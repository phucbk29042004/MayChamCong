datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Employee {
  id              Int          @id @default(autoincrement())
  name            String
  baseSalary      Float
  attendBonus     Float        @default(500000)
  bhxhDeduct      Float        @default(0)
  lunchAllowance  Float        @default(50000)
  allowance       Float        @default(0)
  petrolAllowance Float        @default(0)
  createdAt       DateTime     @default(now())
  attendances     Attendance[]
}

model Attendance {
  id         Int      @id @default(autoincrement())
  employeeId Int
  date       DateTime
  status     String
  checkIn    String?
  otHours    Float    @default(0)
  note       String?
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
}
